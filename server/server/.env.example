# Copy to .env and fill in values
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
FROM_EMAIL=from@example.com
TO_EMAIL=to@example.com
PORT=3001
# Optional: comma-separated list of allowed origins for CORS. Leave empty to allow all (dev).
CORS_ALLOWED=http://localhost:5173
# Optional API key to protect the endpoint. If set, clients must send 'x-api-key' header.
API_KEY=change-me
